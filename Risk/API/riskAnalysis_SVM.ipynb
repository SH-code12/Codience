    "   \"metadata\": {},\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"source\": \"## SVM\",\n",
    "   \"id\": \"6bb9c322ac5ce306\"\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"start_time\": \"2026-03-13T22:18:57.330855Z\"\n",
    "    }\n",
    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"from sklearn.svm import SVC\\n\",\n",
    "    \"from sklearn.model_selection import GridSearchCV\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Define parameter grid\\n\",\n",
    "    \"param_grid = {\\n\",\n",
    "    \"    'C': [0.1, 1, 10, 50],            # Regularization strength\\n\",\n",
    "    \"    'kernel': ['linear', 'rbf', 'poly'],  # Kernel type\\n\",\n",
    "    \"    'gamma': ['scale', 'auto'],        # Kernel coefficient for 'rbf' and 'poly'\\n\",\n",
    "    \"    'degree': [2, 3, 4]                # Only used for 'poly'\\n\",\n",
    "    \"}\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Create SVM\\n\",\n",
    "    \"svc = SVC(probability=True)  # probability=True to get predicted probabilities\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Grid search with 5-fold CV\\n\",\n",
    "    \"grid_search = GridSearchCV(svc, param_grid, cv=5, scoring='f1', n_jobs=-1, verbose=2)\\n\",\n",
    "    \"grid_search.fit(X_train, y_train)\"\n",
    "   ],\n",
    "   \"id\": \"2ef5b5fdcef583db\",\n",
