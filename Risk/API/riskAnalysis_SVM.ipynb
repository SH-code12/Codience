    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"X_test= test.drop(['buggy','commit_id','project','fix','year','author_date',\\\"fix\\\"],axis=1)\\n\",\n",
    "    \"y_test= test['buggy']\"\n",
    "   ],\n",
