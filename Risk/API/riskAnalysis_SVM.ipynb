    "   \"metadata\": {},\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"from sklearn.metrics import accuracy_score, f1_score, roc_auc_score\\n\",\n",
    "    \"\\n\",\n",
    "    \"best_svc = grid_search.best_estimator_\\n\",\n",
