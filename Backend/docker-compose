version: '3.9'
services:
  db:
    image: postgres:16
    environment:
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: postgres
      POSTGRES_DB: codience
    ports:
      - "5432:5432"
  api:
    build: ./Backend
    ports:
      - "5000:5000"
    environment:
      ConnectionStrings__Default: "Host=db;Port=5432;Database=codience;Username=postgres;Password=postgres"
    depends_on:
      - db
